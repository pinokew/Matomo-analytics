#---- Images ---
MATOMO_IMAGE=matomo:apache
MARIADB_IMAGE=mariadb:11
CRON_IMAGE=matomo:fpm-alpine

# --- Database ---
DB_ROOT_PASS=CHANGE_ME
DB_NAME=matomo
DB_USER=matomo
DB_PASS=CHANGE_ME
DB_PREFIX=matomo_

# --- Volumes ---
VOL_DB_PATH=/srv/Matomo/./.data/db
VOL_MATOMO_DATA=/srv/Matomo/./.data/matomo

# --- Matomo ---
MATOMO_HOST=analytics.mylibrary.edu
MATOMO_API_TOKEN=CHANGE_ME

# --- Matomo IaC config (optional overrides) ---
# Defaults in scripts/apply-matomo-config.sh are used if omitted.
MATOMO_CFG_FORCE_SSL=1
MATOMO_CFG_LOGIN_ALLOW_SIGNUP=0
MATOMO_CFG_LOGIN_ALLOW_RESET_PASSWORD=0
MATOMO_CFG_ENABLE_BROWSER_ARCHIVING_TRIGGERING=0
MATOMO_CFG_IGNORE_VISITS_DO_NOT_TRACK=1
MATOMO_CFG_ENABLE_LOGIN_OIDC=1
MATOMO_CFG_OIDC_ALLOW_SIGNUP=0
MATOMO_CFG_OIDC_AUTO_LINKING=1
MATOMO_CFG_OIDC_USERINFO_ID=email
MATOMO_CFG_SMTP_HOST=smtp.office365.com
MATOMO_CFG_SMTP_PORT=587
MATOMO_CFG_SMTP_TRANSPORT=smtp
MATOMO_CFG_SMTP_TYPE=Login
MATOMO_CFG_SMTP_ENCRYPTION=tls
MATOMO_CFG_SMTP_FROM_NAME="Matomo Analytics"
# MATOMO_CFG_SMTP_FROM_ADDRESS defaults to SMTP_USER if omitted

# --- Backup ---
BACKUP_DIR=/srv/Matomo/./.backups
BACKUP_RETENTION_DAYS=14
RCLONE_REMOTE=CHANGE_ME
RCLONE_DEST_PATH=CHANGE_ME

# --- Monitoring thresholds ---
DISK_WARN_THRESHOLD=80
DISK_CRIT_THRESHOLD=90

# --- Restore smoke metrics (optional) ---
NODE_EXPORTER_TEXTFILE_DIR=/srv/victoriametrics-grafana/.data/node-exporter-textfile
RESTORE_SMOKE_METRICS_FILE=matomo_restore_smoke.prom
RESTORE_SMOKE_ENV_LABEL=prod
RESTORE_SMOKE_SERVICE_LABEL=matomo
RESTORE_SMOKE_TIMEOUT_SECONDS=90

# --- Backup metrics (optional) ---
BACKUP_METRICS_FILE=matomo_backup.prom
BACKUP_METRICS_ENV_LABEL=prod
BACKUP_METRICS_SERVICE_LABEL=matomo

ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME

# ---- SMTP (optional, for email notifications) ---
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME